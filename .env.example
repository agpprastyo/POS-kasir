# ==============================================
# Server & Application Config
# ==============================================
APP_ENV=production
APP_NAME=POS-Kasir
APP_PORT=8080

# Kosongkan jika FE & BE di origin yang sama (single port)
# Isi jika FE diakses dari domain lain, contoh: http://localhost:3000
CORS_ALLOW_ORIGINS=

# ==============================================
# Database (PostgreSQL) - WAJIB
# ==============================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=pos_user
DB_PASSWORD=GANTI_PASSWORD_INI
DB_NAME=pos_kasir
DB_SSLMODE=disable

DB_MAX_OPEN_CONNECTIONS=10
DB_MAX_IDLE_CONNECTIONS=2
DB_MAX_LIFETIME_MINUTES=10

# ==============================================
# Migration
# ==============================================
AUTO_MIGRATE=true
MIGRATIONS_PATH=./sqlc/migrations

# ==============================================
# Logger
# ==============================================
LOG_LEVEL=info
LOG_JSON_FORMAT=true

# ==============================================
# JWT (Authentication) - WAJIB
# ==============================================
# Generate secret: openssl rand -hex 32
JWT_SECRET=GANTI_SECRET_INI
JWT_DURATION_HOURS=24
JWT_ISSUER=poskasir

# ==============================================
# Midtrans (Payment Gateway) - Opsional
# ==============================================
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PROD=false

# ==============================================
# Object Storage (S3-compatible) - Opsional
# Untuk MinIO lokal: R2_PUBLIC_DOMAIN=http://localhost:9000
# ==============================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY=minioadmin
R2_SECRET_KEY=minioadmin
R2_BUCKET=pos-kasir
R2_PUBLIC_DOMAIN=
R2_EXPIRY_SECONDS=3600
